# syntax=docker/dockerfile:1

FROM docker.io/library/node:24-alpine AS builder

ARG VERSION

ENV NEXT_PUBLIC_API_URL="" \
    REMOTE_API_URL="http://backend:8080" \
    STANDALONE="true"

RUN apk add --no-cache git patch

RUN corepack enable && corepack prepare pnpm@10.28.2 --activate

WORKDIR /src

RUN git clone --depth 1 --branch "${VERSION}" https://github.com/multica-ai/multica.git .

COPY ./patches/ /tmp/patches/

RUN grep -F 'apiBaseUrl={process.env.NEXT_PUBLIC_API_URL}' /src/apps/web/components/web-providers.tsx \
    && grep -F 'const remoteApiUrl = resolveRemoteApiUrl(process.env);' /src/apps/web/next.config.ts \
    && for patch_file in /tmp/patches/*.patch; do patch -p1 --forward --fuzz=3 < "$patch_file" || true; done \
    && grep -F 'proxyClientMaxBodySize: "1gb"' /src/apps/web/next.config.ts \
    && grep -F 'variable: "--font-inter"' /src/apps/web/app/layout.tsx \
    && grep -F -- '--font-sans: var(--font-inter)' /src/apps/web/app/globals.css \
    && pnpm install --frozen-lockfile \
    && pnpm --filter @multica/web build

FROM docker.io/library/node:24-alpine AS runner

RUN apk add --no-cache catatonit

WORKDIR /app

ENV HOME="/config" \
    HOSTNAME="0.0.0.0" \
    NODE_ENV="production" \
    PORT="3000"

RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 --ingroup nodejs nextjs \
    && mkdir -p /config

COPY --from=builder --chown=nextjs:nodejs /src/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /src/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /src/apps/web/public ./apps/web/public
COPY --chown=nextjs:nodejs ./entrypoint.web.sh /entrypoint.sh

RUN chmod 755 /entrypoint.sh \
    && chown -R nextjs:nodejs /app /config

USER nextjs
VOLUME ["/config"]

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://127.0.0.1:3000/ | grep -q "Multica" || exit 1

ENTRYPOINT ["/usr/bin/catatonit", "--", "/entrypoint.sh"]
